SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/nap_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=nap_db_password

# Esquema de la BD. El default del código es seguro (update + sin seed), pensado para prod.
# DESARROLLO: anula para tener esquema efímero + seed (admin/admin, user01/user01):
#   SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
#   SPRING_SQL_INIT_MODE=always

# Orígenes permitidos para CORS (lista separada por comas). Por defecto: http://localhost:4200
# En prod, la URL del frontend en Vercel (p. ej. https://nap-frontend.vercel.app).
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200

JWT_ACCESS_EXP_MIN=15

JWT_REFRESH_EXP_DAYS=7

# Cookie del refresh token. secure=true solo con HTTPS (producción).
JWT_COOKIE_SECURE=false

# SameSite de la cookie: Lax | Strict | None.
# Dev (front y API en localhost): Lax.
# Prod (front en Vercel, API en Render = sitios distintos): None (con secure=true), obligatorio.
JWT_COOKIE_SAMESITE=Lax
